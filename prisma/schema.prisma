generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String           @id @default(cuid())
  name                  String?
  email                 String?          @unique
  phone                 String?          @unique
  provider              String?
  googleId              String?          @unique
  appleId               String?          @unique
  passwordHash          String?
  avatar                String?
  isAdmin               Boolean          @default(false)
  acceptedTermsAt       DateTime?
  acceptedPrivacyAt     DateTime?
  acceptedPolicyVersion String?
  marketingConsent      Boolean          @default(false)
  marketingConsentAt    DateTime?
  emailNotifications    Boolean          @default(true)
  smsNotifications      Boolean          @default(false)
  whatsappNotifications Boolean          @default(false)
  preferredContactChannel String         @default("email")
  defaultShippingAddress String?
  defaultShippingCity   String?
  lastSignInAt          DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @default(now()) @updatedAt
  orders                Order[]
  reviews               Review[]
  sessions              AuthSession[]
  analyticsEvents       AnalyticsEvent[]
}

model AuthSession {
  id        String    @id @default(cuid())
  token     String    @unique
  scope     AuthScope @default(CUSTOMER)
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  sku             String?  @unique
  category        String
  size            String
  badge           String?
  short           String
  price           Int
  potOnly         Int?
  description     String   @db.Text
  cardDescription String   @db.Text
  image           String
  gallery         Json?
  decorative      Boolean  @default(false)
  forcePotOnly    Boolean  @default(false)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  details         Json
  plantGuide      Json?
  visible         Boolean  @default(true)
  available       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  reviews         Review[]
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  trackingCode  String?       @unique
  userId        String?
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  isCustomOrder Boolean       @default(false)
  customerName  String
  customerEmail String
  customerPhone String
  subtotal      Int
  deliveryFee   Int
  totalAmount   Int
  currency      String        @default("KES")
  shippingAddr1 String?
  shippingAddr2 String?
  shippingCity  String?
  shippingNotes String?
  attributionSource String?
  attributionMedium String?
  attributionCampaign String?
  attributionTerm String?
  attributionContent String?
  gclid         String?
  fbclid        String?
  landingPath   String?
  trackingSessionKey String?
  estimatedDispatchAt DateTime?
  estimatedDeliveryAt DateTime?
  trackingTimeline Json?
  notificationLog Json?
  adminNotes    String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productSlug String
  sku         String?
  name        String
  image       String?
  mode        String
  sizeLabel   String?
  unitPrice   Int
  quantity    Int
  lineTotal   Int
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id                  String          @id @default(cuid())
  orderId             String
  provider            PaymentProvider
  status              PaymentStatus   @default(PENDING)
  amount              Int
  currency            String          @default("KES")
  externalRef         String?
  checkoutUrl         String?
  providerRequestId   String?
  providerResponseRaw String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StudioBrief {
  id            String            @id @default(cuid())
  referenceCode String            @unique
  status        StudioBriefStatus @default(RECEIVED)
  source        String            @default("studio")
  message       String
  imageFileName String?
  imagePreview  String?
  referenceLink String?
  space         String
  helpType      String
  extraNote     String?
  summary       String
  internalNotes String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String               @db.Text
  context   String?
  imageUrl  String?
  status    ContactMessageStatus @default(NEW)
  readAt    DateTime?
  handledAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @default(now()) @updatedAt
}

model NewsletterSubscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  preferredChannel String?
  interests        Json?
  source           String?
  createdAt        DateTime @default(now())
}

model SiteSection {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  route     String?
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  name      String
  rating    Int
  body      String   @db.Text
  approved  Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AnalyticsEvent {
  id           String   @id @default(cuid())
  userId       String?
  sessionKey   String?
  eventName    String
  path         String?
  source       String?
  consentLevel String
  payload      Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum AuthScope {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  MPESA
}

enum PaymentMethod {
  CARD
  MPESA
}

enum PaymentStatus {
  PENDING
  INITIATED
  SUCCESS
  FAILED
}

enum StudioBriefStatus {
  RECEIVED
  REVIEWING
  RESPONDED
  CLOSED
}

enum ContactMessageStatus {
  NEW
  READ
  HANDLED
}
