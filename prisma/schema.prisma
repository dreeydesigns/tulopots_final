generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  phone     String?  @unique
  provider  String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String?
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  customerName  String
  customerEmail String
  customerPhone String
  subtotal      Int
  deliveryFee   Int
  totalAmount   Int
  currency      String        @default("KES")
  shippingAddr1 String?
  shippingAddr2 String?
  shippingCity  String?
  shippingNotes String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productSlug String
  sku         String?
  name        String
  image       String?
  mode        String
  sizeLabel   String?
  unitPrice   Int
  quantity    Int
  lineTotal   Int
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id                  String          @id @default(cuid())
  orderId             String
  provider            PaymentProvider
  status              PaymentStatus   @default(PENDING)
  amount              Int
  currency            String          @default("KES")
  externalRef         String?
  checkoutUrl         String?
  providerRequestId   String?
  providerResponseRaw String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StudioBrief {
  id            String            @id @default(cuid())
  referenceCode String            @unique
  status        StudioBriefStatus @default(RECEIVED)
  source        String            @default("studio")
  message       String
  imageFileName String?
  imagePreview  String?
  referenceLink String?
  space         String
  helpType      String
  extraNote     String?
  summary       String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  FAILED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  MPESA
}

enum PaymentMethod {
  CARD
  MPESA
}

enum PaymentStatus {
  PENDING
  INITIATED
  SUCCESS
  FAILED
}

enum StudioBriefStatus {
  RECEIVED
  REVIEWING
  RESPONDED
  CLOSED
}
