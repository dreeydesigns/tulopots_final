# ═══════════════════════════════════════════════════════════════════
#  TuloPots — Environment Variables
#  Copy this file to .env.local for local dev
#  In Vercel or Railway: add each key to your project environment
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# Local dev: your local Postgres or shared remote Postgres
# Production: use the existing Railway PostgreSQL URL for now
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Site URL ──────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Vercel:    your production deployment URL or custom domain
# Note:      on Vercel, the app can also fall back to the built-in
#            project production URL automatically if this is omitted
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Stripe (Card Payments) ────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for sandbox, sk_live_... for production
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"

# Stripe webhook secret — from Stripe Dashboard → Webhooks
# Add endpoint: https://YOUR_DOMAIN/api/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# KES → USD conversion rate (Stripe requires USD)
# Default: 130 (1 USD = 130 KES). Update if rate changes.
STRIPE_KES_TO_USD_RATE="130"

# ── M-Pesa / Safaricom Daraja ─────────────────────────────────────
# Get credentials from: https://developer.safaricom.co.ke
# Sandbox: https://sandbox.safaricom.co.ke
# Production: https://api.safaricom.co.ke
MPESA_BASE_URL="https://sandbox.safaricom.co.ke"
MPESA_CONSUMER_KEY="REPLACE_ME"
MPESA_CONSUMER_SECRET="REPLACE_ME"
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="REPLACE_ME"

# Must be a public HTTPS URL
# Format: https://YOUR_DOMAIN/api/payments/mpesa/callback
MPESA_CALLBACK_URL="https://YOUR_DOMAIN/api/payments/mpesa/callback"

# ── Auth / Social Sign-In ─────────────────────────────────────────
GOOGLE_CLIENT_ID="REPLACE_ME"
GOOGLE_CLIENT_SECRET="REPLACE_ME"
# Optional if you want to override the default callback built from the request host
GOOGLE_REDIRECT_URI="https://YOUR_DOMAIN/api/auth/oauth/callback/google"
# Optional for Google Search Console HTML tag verification
GOOGLE_SITE_VERIFICATION="REPLACE_ME"

APPLE_CLIENT_ID="REPLACE_ME"
APPLE_TEAM_ID="REPLACE_ME"
APPLE_KEY_ID="REPLACE_ME"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
# Optional if you want to override the default callback built from the request host
APPLE_REDIRECT_URI="https://YOUR_DOMAIN/api/auth/oauth/callback/apple"

# ── Analytics / Ads ───────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GOOGLE_ADS_ID="AW-XXXXXXXXX"

# ── Admin / Contact Defaults ──────────────────────────────────────
ADMIN_EMAILS="andrew@tulopots.com,admin@tulopots.com,dreeydesigns@gmail.com"

# ── WhatsApp (for chatbot handoff) ────────────────────────────────
# Your TuloPots WhatsApp business number in international format
WHATSAPP_NUMBER="254700000000"

# ── AI Chatbot ────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-REPLACE_ME"

# ── Operations Automation ─────────────────────────────────────────
# Optional bearer token for scheduled calls to /api/admin/automation
OPERATIONS_AUTOMATION_SECRET="REPLACE_ME"
